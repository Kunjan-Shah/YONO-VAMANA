<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ── VAMANA-Verify: TEE-backed transaction confirmation ────────────── -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!--
    ── Root-management package visibility ──────────────────────────────────
       HealthCheckEngine's DEVICE_ROOTED check looks for these specific
       packages by name. Without declaring them here, PackageManager would
       report them as not installed even when they are (API 30+ package
       visibility filtering), silently weakening the check.
    -->
    <queries>
        <package android:name="com.topjohnwu.magisk" />
        <package android:name="eu.chainfire.supersu" />
        <package android:name="com.noshufou.android.su" />
        <package android:name="com.koushikdutta.superuser" />
        <package android:name="com.thirdparty.superuser" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.YONOVAMANA">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.YONOVAMANA">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
        ── VAMANA-Isolate work profile admin receiver ─────────────────────
           Device Policy Controller for the isolated work profile created
           from the VAMANA-Isolate screen. exported=true and BIND_DEVICE_ADMIN
           are required so the system can deliver admin lifecycle intents to it.
        -->
        <receiver
            android:name=".vamana.isolate.WorkProfileAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/vamana_isolate_device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.PROFILE_PROVISIONING_COMPLETE" />
            </intent-filter>
        </receiver>
    </application>

</manifest>